# Colophon — example secrets file.
# Copy this to .env and fill in your values. Never commit .env to git.

# Claude API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (https://platform.openai.com/api-keys) — needed for openai/ models
# OPENAI_API_KEY=sk-...

# Optional: override the default LLM model
# COLOPHON_LLM_MODEL=anthropic/claude-haiku-4-5

# Optional: use an OpenAI model (6-7x cheaper than Haiku; try for cost benchmarking)
# COLOPHON_LLM_MODEL=openai/gpt-4o-mini

# Optional: use a local Ollama model instead
# COLOPHON_LLM_MODEL=ollama/gemma3:12b

# Optional: custom Ollama endpoint (e.g. a machine on your Tailnet)
# COLOPHON_OLLAMA_URL=http://100.122.243.79:11434
# COLOPHON_NUM_CTX=262144
