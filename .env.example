# Colophon — example secrets file.
# Copy this to .env and fill in your values. Never commit .env to git.

# Claude API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (https://platform.openai.com/api-keys) — needed for openai/ models
# OPENAI_API_KEY=sk-...

# OpenRouter API key (https://openrouter.ai/settings/keys) — proxy for 200+ models
# OPENROUTER_API_KEY=sk-or-v1-...

# Optional: override the default LLM model (also settable via --llm on CLI)
# COLOPHON_LLM_MODEL=anthropic/claude-haiku-4-5

# Optional: use an OpenAI model (cheaper than Haiku; try for cost benchmarking)
# COLOPHON_LLM_MODEL=openai/gpt-5.4-mini
# COLOPHON_LLM_MODEL=openai/gpt-5.4-nano    # cheapest extraction baseline

# Optional: OpenAI Batch API (~50% cheaper, up to 24h turnaround)
# Pass --use-batch on the CLI, or set in config. Only active for openai/ models.

# Optional: route through OpenRouter (access GLM, DeepSeek, etc.)
# COLOPHON_LLM_MODEL=openrouter/z-ai/glm-5.2
# COLOPHON_LLM_MODEL=openrouter/deepseek/deepseek-r2

# Optional: use a local Ollama model instead
# COLOPHON_LLM_MODEL=ollama/gemma3:12b

# Optional: custom Ollama endpoint (e.g. a machine on your Tailnet)
# COLOPHON_OLLAMA_URL=http://100.122.243.79:11434
# COLOPHON_NUM_CTX=262144

# Optional: chars per Stage 1 chunk (default 32K). Raise for large-context
# models — e.g. 600000 sends a whole mid-size novel in one shot for the best
# cross-book entity resolution. Watch the model's max output tokens.
# COLOPHON_MAX_CHUNK_CHARS=600000

# Optional: chunks analyzed in parallel in Stage 1 (default 4).
# Set to 1 for a local Ollama server or to stay under a tight rate limit.
# COLOPHON_CONCURRENCY=4
